<ENVELOPE>
  <HEADER>
    <VERSION>1</VERSION>
    <TALLYREQUEST>Export</TALLYREQUEST>
    <TYPE>Object</TYPE>
    <SUBTYPE>StockItem</SUBTYPE>
    <ID TYPE="Name">{{STOCKITEM}}</ID>
  </HEADER>
  <BODY>
